                    <actionList>
                        <setInstallerVariable name="blender_4_path" value="${blender_4_path}/Contents/MacOS/Blender" />
                    </actionList>
                </if>
                <fnUnsetBlenderPref blenderPath="${blender_4_path}"/>
            </preUninstallationActionList>
        </component>
